# Optional: GitHub Personal Access Token for higher API rate limits (60/hr → 5000/hr)
# Create at: https://github.com/settings/tokens (no special scopes needed for public profiles)
GITHUB_TOKEN=

# Optional: LinkedIn OAuth app credentials (for the /auth/linkedin/* endpoints in api.py)
# Create at: https://www.linkedin.com/developers/apps
# Register this exact redirect URI in the app's Auth settings:
#   http://localhost:8000/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Optional: override default OAuth scopes if your LinkedIn app doesn't have
# r_basicprofile approved (most apps only have the OpenID Connect product):
# LINKEDIN_SCOPES=openid profile email

# Optional: Postgres connection string for --save-to-db / the /candidates API
# e.g. postgresql://user:password@localhost:5432/AssignmentDB
DATABASE_URL=
